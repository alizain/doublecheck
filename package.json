{
	"name": "doublecheck",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.1",
	"bin": {
		"doublecheck": "src/cli.ts"
	},
	"scripts": {
		"doublecheck": "tsx src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"microsandbox": "^0.6.2",
		"p-queue": "^9.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^24.0.0",
		"tsx": "^4.22.4",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
